APP_NAME="NovarexHSE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Dar_es_Salaam
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portalhse
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ----------------------------------------------------------------
# Mail — SMTP via support@novarex.co.tz
# ----------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mail.novarex.co.tz
MAIL_PORT=465
MAIL_USERNAME=support@novarex.co.tz
MAIL_PASSWORD=P@98@W9B*cgrGsM
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="support@novarex.co.tz"
MAIL_FROM_NAME="NovarexHSE"

# ----------------------------------------------------------------
# PDF (barryvdh/laravel-dompdf)
# ----------------------------------------------------------------
DOMPDF_PAPER_SIZE=a4
DOMPDF_ORIENTATION=portrait

# ----------------------------------------------------------------
# AWS (optional — only if using S3 for file storage)
# ----------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
